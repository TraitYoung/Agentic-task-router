# ===== 必需：千问兼容配置 =====
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ===== 可选：A 方向步骤级模型路由 =====
# 不填则回退到 QWEN_MODEL / AX_LLM_DEFAULT_MODEL
AX_LLM_API_KEY=
AX_LLM_BASE_URL=
AX_LLM_DEFAULT_MODEL=qwen-plus
AX_LLM_DISCOVERY_MODEL=qwen-plus
AX_LLM_SPRINT_MODEL=qwen-plus
AX_LLM_IMPLEMENTATION_MODEL=qwen-plus
AX_LLM_DELIVERY_MODEL=qwen-plus
AX_LLM_MERGE_MODEL=qwen-plus

# ===== 现有运行配置 =====
REDIS_URL=redis://localhost:6379/0

# ===== 上下文预算（可选） =====
AX_PARSER_HISTORY_MAX_CHARS=3500
AX_PARSER_HISTORY_LINE_MAX_CHARS=1200
AX_JEAN_MATERIALS_MAX_CHARS=2000
AX_WORKFLOW_USER_MAX_CHARS=8000
AX_WORKFLOW_STEP_JSON_MAX_CHARS=2500

